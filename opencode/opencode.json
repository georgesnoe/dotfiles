{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer {env:GITHUB_PERSONAL_ACCESS_TOKEN}"
      },
      "oauth": false,
      "timeout": 30000,
      "enabled": false
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp@latest"],
      "timeout": 30000,
      "enabled": false,
      "environment": {
        "PLAYWRIGHT_MCP_BROWSER": "firefox",
        "PLAYWRIGHT_MCP_HEADLESS": "0",
        "PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD": "0"
      }
    },
    "notion": {
      "type": "remote",
      "url": "https://mcp.notion.com/mcp",
      "timeout": 30000,
      "enabled": false
    }
  },
  "model": "google/gemma-4-31b-it",
  "small_model": "google/gemini-3.1-flash-lite-preview",
  "enabled_providers": ["google"],
  "default_agent": "plan",
  "autoupdate": "notify",
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 15000
  },
  "watcher": {
    "ignore": [
      ".git/**",
      ".idea/**",
      "node_modules/**",
      "__pycache__/**",
      ".next/**",
      ".gradle/**",
      ".tanstack/**",
      "dist/**",
      "build/**",
      ".output/**"
    ]
  },
  "instructions": ["CLAUDE.md", "AGENTS.md", "DESIGN.md", "STYLE.md"],
  "provider": {
    "google": {
      "options": {
        "chunkTimeout": 30000,
        "timeout": false,
        "apiKey": "{env:GEMINI_API_KEY}"
      },
      "models": {
        "gemma-4-31b-it": {
          "id": "gemma-4-31b-it",
          "name": "Gemma 4 31B (Dense)",
          "family": "gemma",
          "tool_call": true,
          "release_date": "April 2, 2026",
          "reasoning": true,
          "cost": {
            "input": 0.13,
            "output": 0.38
          },
          "modalities": {
            "input": ["text", "audio", "image", "pdf"],
            "output": ["text"]
          },
          "attachment": true,
          "limit": {
            "input": 32000,
            "output": 32000,
            "context": 256000
          },
          "variants": {
            "minimal": {
              "reasoningEffort": "minimal",
              "textVerbosity": "low",
              "reasoningSummary": "auto"
            },
            "high": {
              "reasoningEffort": "high",
              "textVerbosity": "low",
              "reasoningSummary": "auto"
            }
          }
        },
        "gemma-4-26b-a4b-it": {
          "id": "gemma-4-26b-a4b-it",
          "name": "Gemma 4 26B (MoE)",
          "family": "gemma",
          "tool_call": true,
          "release_date": "April 2, 2026",
          "reasoning": true,
          "cost": {
            "input": 0.07,
            "output": 0.34
          },
          "modalities": {
            "input": ["text", "audio", "image", "pdf"],
            "output": ["text"]
          },
          "attachment": true,
          "limit": {
            "input": 32000,
            "output": 32000,
            "context": 256000
          },
          "variants": {
            "minimal": {
              "reasoningEffort": "minimal",
              "textVerbosity": "low",
              "reasoningSummary": "auto"
            },
            "high": {
              "reasoningEffort": "high",
              "textVerbosity": "low",
              "reasoningSummary": "auto"
            }
          }
        },
        "gemini-3.1-flash-lite-preview": {
          "id": "gemini-3.1-flash-lite-preview",
          "name": "Gemini 3.1 Flash Lite (Preview)",
          "family": "gemini",
          "tool_call": true,
          "release_date": "March 2, 2026",
          "reasoning": true,
          "cost": {
            "input": 0.25,
            "output": 1.5
          },
          "modalities": {
            "input": ["text", "audio", "image", "pdf"],
            "output": ["text"]
          },
          "limit": {
            "input": 32000,
            "output": 65000,
            "context": 1000000
          },
          "attachment": true,
          "variants": {
            "minimal": {
              "reasoningEffort": "minimal",
              "textVerbosity": "low",
              "reasoningSummary": "auto"
            },
            "low": {
              "reasoningEffort": "low",
              "textVerbosity": "low",
              "reasoningSummary": "auto"
            },
            "medium": {
              "reasoningEffort": "medium",
              "textVerbosity": "low",
              "reasoningSummary": "auto"
            },
            "high": {
              "reasoningEffort": "high",
              "textVerbosity": "low",
              "reasoningSummary": "auto"
            }
          }
        }
      }
    }
  }
}
